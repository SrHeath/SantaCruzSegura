# Environment variables for Santa Cruz Segura
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=REPLACE_WITH_GENERATED_SECURE_KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourusername.pythonanywhere.com

# Database
DB_NAME=santa_cruz_segura
DB_USER=santacruz
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=3306